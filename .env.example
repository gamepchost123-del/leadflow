# Copy to .env and fill in. Also set these in Vercel → Project → Settings → Environment Variables.

# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- Google Custom Search (web search engine) ---
GOOGLE_API_KEY=""
GOOGLE_CSE_ID=""

# --- SMTP (Porkbun) for outreach mail ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME=""
SMTP_FROM_EMAIL=""

# --- GoHighLevel (LeadConnector) pipeline sync ---
# Private Integration Token from: sub-account → Settings → Private Integrations
# Scopes needed: contacts.write, contacts.readonly, opportunities.write, opportunities.readonly
GHL_API_TOKEN=""
# Sub-account (location) id: Settings → Business Profile, or the /v2/location/ id
GHL_LOCATION_ID=""
# Target pipeline + stage BY NAME (resolved to ids automatically at runtime)
GHL_PIPELINE_NAME=""
GHL_PIPELINE_STAGE_NAME=""
# Optional: pin exact ids instead of names (these win over the *_NAME vars)
# GHL_PIPELINE_ID=""
# GHL_PIPELINE_STAGE_ID=""
